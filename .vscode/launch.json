{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Debug Serverless Offline",
            "program": "${workspaceFolder}/node_modules/serverless/run.js",
            "args": [
                "offline",
                "--noPrependStageInUrl"
            ],
            "windows": {
                "program": "${workspaceFolder}/node_modules/serverless/run.js"
            },
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen",
            "env": {
                "NODE_ENV": "development",
                "SLS_DEBUG": "*"
            }
        }
    ]
}